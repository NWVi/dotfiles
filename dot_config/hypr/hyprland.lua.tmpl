---------------------
---- KEYBINDINGS ----
---------------------

local mainMod = "SUPER"

-- See https://wiki.hypr.land/Configuring/Basics/Binds/
hl.bind(mainMod .. " + RETURN", hl.dsp.exec_cmd("ghostty --gtk-single-instance=true"))
hl.bind(mainMod .. " + SHIFT + Q", hl.dsp.window.close())
hl.bind(mainMod .. " + SHIFT + SPACE", hl.dsp.window.float({ action = "toggle" }))
hl.bind(mainMod .. " + F", hl.dsp.window.fullscreen({ action = "toggle", mode = "fullscreen" }))
hl.bind(mainMod .. " + P", hl.dsp.window.pseudo()) -- dwindle
hl.bind(mainMod .. " + S", hl.dsp.layout("togglesplit")) -- dwindle

-- Menus
hl.bind(mainMod .. " + D", hl.dsp.exec_cmd("~/.config/rofi/scripts/launcher.sh"))
hl.bind(mainMod .. " + SHIFT + E", hl.dsp.exec_cmd("~/.config/rofi/scripts/powermenu.sh"))
hl.bind(mainMod .. " + SHIFT + S", hl.dsp.exec_cmd("~/.local/bin/grimblast copy area"))

-- Focus / move / resize with arrows and hjkl
local moves = {
	{ keys = { "left", "H" }, dir = "left", resize = { x = -30, y = 0 } },
	{ keys = { "right", "L" }, dir = "right", resize = { x = 30, y = 0 } },
	{ keys = { "up", "K" }, dir = "up", resize = { x = 0, y = -30 } },
	{ keys = { "down", "J" }, dir = "down", resize = { x = 0, y = 30 } },
}
for _, m in ipairs(moves) do
	for _, key in ipairs(m.keys) do
		hl.bind(mainMod .. " + " .. key, hl.dsp.focus({ direction = m.dir }))
		hl.bind(mainMod .. " + SHIFT + " .. key, hl.dsp.window.move({ direction = m.dir }))
		hl.bind(
			mainMod .. " + ALT + " .. key,
			hl.dsp.window.resize({ x = m.resize.x, y = m.resize.y, relative = true })
		)
	end
end

-- Switch to / move window to workspaces 1-10 (key 0 -> workspace 10)
for i = 1, 10 do
	local key = i % 10
	hl.bind(mainMod .. " + " .. key, hl.dsp.focus({ workspace = i }))
	hl.bind(mainMod .. " + SHIFT + " .. key, hl.dsp.window.move({ workspace = i }))
end

-- Scratchpad / special workspace
hl.bind(mainMod .. " + SHIFT + MINUS", hl.dsp.window.move({ workspace = "special" }))
hl.bind(mainMod .. " + MINUS", hl.dsp.workspace.toggle_special())

-- Scroll through workspaces with mainMod + scroll
hl.bind(mainMod .. " + mouse_down", hl.dsp.focus({ workspace = "e+1" }))
hl.bind(mainMod .. " + mouse_up", hl.dsp.focus({ workspace = "e-1" }))

-- Move / resize windows with mainMod + SHIFT + LMB/RMB and dragging
hl.bind(mainMod .. " + SHIFT + mouse:272", hl.dsp.window.drag(), { mouse = true })
hl.bind(mainMod .. " + SHIFT + mouse:273", hl.dsp.window.resize(), { mouse = true })

-- Volume controls
hl.bind(
	"XF86AudioRaiseVolume",
	hl.dsp.exec_cmd("wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+"),
	{ locked = true, repeating = true }
)
hl.bind(
	"XF86AudioLowerVolume",
	hl.dsp.exec_cmd("wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"),
	{ locked = true, repeating = true }
)
hl.bind("XF86AudioMute", hl.dsp.exec_cmd("wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"), { locked = true })

-- Media controls
hl.bind("XF86AudioPrev", hl.dsp.exec_cmd("playerctl previous"), { locked = true })
hl.bind("XF86AudioNext", hl.dsp.exec_cmd("playerctl next"), { locked = true })
hl.bind("XF86AudioPlay", hl.dsp.exec_cmd("playerctl play-pause"), { locked = true })

if host == "Archie" then
	-- Brightness controls
	hl.bind("XF86MonBrightnessUp", hl.dsp.exec_cmd("brightnessctl -s set +5%"), { locked = true })
	hl.bind("XF86MonBrightnessDown", hl.dsp.exec_cmd("brightnessctl -s set 5%-"), { locked = true })
end

--------------------------------
---- WINDOWS AND WORKSPACES ----
--------------------------------

-- See https://wiki.hypr.land/Configuring/Basics/Window-Rules/
hl.window_rule({ match = { class = "^(discord)$" }, workspace = "special silent" })
hl.window_rule({ match = { class = "^(Spotify)$" }, workspace = "special silent" })
hl.window_rule({ match = { class = "^(Slack)$" }, workspace = "special silent" })

hl.window_rule({ match = { class = "(.*)" }, opacity = "1.0 override 0.9 override" })

-- XWayland video bridge fix
-- https://wiki.hypr.land/Useful-Utilities/Screen-Sharing/#xwayland
hl.window_rule({
	name = "xwayland-video-bridge-fixes",
	match = { class = "xwaylandvideobridge" },

	no_initial_focus = true,
	no_focus = true,
	no_anim = true,
	no_blur = true,
	max_size = "1 1",
	opacity = "0.0",
})
