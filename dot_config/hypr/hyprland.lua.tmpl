-- Hyprland configuration (Lua API, Hyprland >= 0.55).
-- Refer to the wiki: https://wiki.hypr.land/
--
-- Managed by chezmoi. The ONLY templated value is the hostname below; everything
-- else branches with native Lua so this stays a normal, LSP-checkable Lua file.
local host = "{{ .chezmoi.hostname }}"

-------------------------------
---- ENVIRONMENT VARIABLES ----
-------------------------------

if host == "Archer" then
	-- Nvidia
	hl.env("LIBVA_DRIVER_NAME", "nvidia")
	hl.env("__GLX_VENDOR_LIBRARY_NAME", "nvidia")
	hl.env("__GL_GSYNC_ALLOWED", "1")
	hl.env("WEBKIT_DISABLE_DMABUF_RENDERER", "1")
	hl.env("WEBKIT_DISABLE_COMPOSITING_MODE", "1")
end

hl.env("GDK_SCALE", "1")
hl.env("GDK_BACKEND", "wayland,x11,*")
hl.env("GTK_THEME", "Kanagawa-B-LB")
hl.env("CLUTTER_BACKEND", "wayland")

hl.env("XDG_CURRENT_DESKTOP", "Hyprland")
hl.env("XDG_SESSION_TYPE", "wayland")
hl.env("XDG_SESSION_DESKTOP", "Hyprland")

hl.env("XCURSOR_SIZE", "16")
hl.env("HYPRCURSOR_SIZE", "16")

-- QT
hl.env("QT_QPA_PLATFORM", "wayland;xcb")
hl.env("QT_QPA_PLATFORMTHEME", "qt5ct")
hl.env("QT_WAYLAND_DISABLE_WINDOWDECORATION", "1")
hl.env("QT_AUTO_SCREEN_SCALE_FACTOR", "1")

------------------
---- MONITORS ----
------------------

-- See https://wiki.hypr.land/Configuring/Basics/Monitors/
if host == "Archer" then
	hl.monitor({ output = "DP-1", mode = "2560x1440@120", position = "0x0", scale = 1, bitdepth = 8 })
	hl.monitor({
		output = "HDMI-A-1",
		mode = "1920x1080@60",
		position = "2560x0",
		scale = 1,
		transform = 1,
		bitdepth = 8,
	})
elseif host == "Archie" then
	hl.monitor({ output = "eDP-1", mode = "highrr", position = "0x0", scale = 1, bitdepth = 10 })
elseif host == "seb-archlinux" then
	hl.monitor({ output = "DP-2", mode = "preferred", position = "0x0", scale = 1.25, bitdepth = 10 })
	hl.monitor({ output = "DP-3", mode = "preferred", position = "3072x0", scale = 1.25, bitdepth = 10 })
end
-- Fallback for any other / new monitor
hl.monitor({ output = "", mode = "preferred", position = "auto", scale = "auto" })

-------------------
---- AUTOSTART ----
-------------------

-- See https://wiki.hypr.land/Configuring/Basics/Autostart/
-- exec-once equivalent: run on initial startup.
hl.on("hyprland.start", function()
	hl.exec_cmd("dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP")
	hl.exec_cmd("playerctld daemon")
	hl.exec_cmd("hypridle")
	hl.exec_cmd("dunst")
	hl.exec_cmd("/usr/lib/polkit-kde-authentication-agent-1")
	hl.exec_cmd("hyprshade auto")
	-- fix gnome cursor size...
	hl.exec_cmd("gsettings set org.gnome.desktop.interface cursor-theme Adwaita")

	-- waybar
	hl.exec_cmd("waybar")

	-- Wallpaper
	hl.exec_cmd("awww-daemon")
	if host == "Archer" then
		hl.exec_cmd("awww img -o DP-1 ~/Pictures/wallpapers/Arcane/Arcane.S01E07.The.Boy.Savior.17.53.png")
		hl.exec_cmd("awww img -o HDMI-A-1 ~/Pictures/wallpapers/Arcane/Arcane.S01E07.The.Boy.Savior.17.49.png")
		hl.exec_cmd("awww restore")
	elseif host == "Archie" then
		hl.exec_cmd("awww img -o eDP-1 ~/Pictures/wallpapers/Arcane/Arcane.S01E07.The.Boy.Savior.17.53.png")
	elseif host == "seb-archlinux" then
		hl.exec_cmd("awww img -o DP-2 ~/Pictures/wallpapers/Arcane/Arcane.S01E07.The.Boy.Savior.17.53.png")
		hl.exec_cmd("awww img -o DP-3 ~/Pictures/wallpapers/Arcane/Arcane.S01E07.The.Boy.Savior.17.49.png")
		hl.exec_cmd("awww restore")
	end

	-- Applets
	hl.exec_cmd("nm-applet")
	hl.exec_cmd("blueman-applet")
	if host ~= "seb-archlinux" then
		hl.exec_cmd("dropbox")
	end
	if host == "seb-archlinux" then
		hl.exec_cmd("slack")
		hl.exec_cmd("spotify")
	end
end)

--------------------
---- WORKSPACES ----
--------------------

-- See https://wiki.hypr.land/Configuring/Basics/Workspace-Rules/
-- Workspaces 1-5 -> primary monitor, 6-10 -> secondary monitor.
local primaryMonitor, secondaryMonitor
if host == "Archer" then
	primaryMonitor, secondaryMonitor = "DP-1", "HDMI-A-1"
elseif host == "Archie" then
	primaryMonitor, secondaryMonitor = "eDP-1", "eDP-3"
elseif host == "seb-archlinux" then
	primaryMonitor, secondaryMonitor = "DP-2", "DP-3"
end

if primaryMonitor then
	for i = 1, 10 do
		local monitor = (i <= 5) and primaryMonitor or secondaryMonitor
		hl.workspace_rule({ workspace = tostring(i), monitor = monitor, default = true })
	end
end

---------------
---- INPUT ----
---------------

hl.config({
	input = {
		kb_layout = "us,no",
		kb_options = "grp:alts_toggle",

		follow_mouse = 1,

		sensitivity = 0, -- -1.0 - 1.0, 0 means no modification.

		touchpad = {
			natural_scroll = false,
		},
	},
})

